<Window x:Class="uc2m4a.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:uc2m4a"
        mc:Ignorable="d"
        Title="网易云音乐 UC 格式 缓存文件转换为 M4A 格式" Height="320" Width="320" ResizeMode="CanMinimize" Topmost="True" AllowDrop="True" Icon="/uc2m4a.ico">
    <Window.Resources>

    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 第一行：保存目录 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="保存目录" Style="{StaticResource LabelStyle}"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtSavePath" Text="未选择目录" Style="{StaticResource PathTextBox}" Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="BtnSaveBrowse" Content="浏览..." Style="{StaticResource AccentButton}" Click="BtnSaveBrowse_Click"/>
            </Grid>
        </Grid>

        <!-- 第一行：来源文件 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="来源文件" Style="{StaticResource LabelStyle}"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="TxtSrcPath" Text="未选择文件" Style="{StaticResource PathTextBox}" Margin="0,0,8,0" IsReadOnly="False"/>
                <Button Grid.Column="1" x:Name="BtnSrcBrowse" Content="浏览..." Style="{StaticResource AccentButton}" Click="BtnSrcBrowse_Click"/>
            </Grid>
        </Grid>

        <!-- 第三行：保存类型 -->
        <Grid Grid.Row="2" Margin="0,0,0,16" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="保存目标" Style="{StaticResource LabelStyle}"/>
            <ComboBox Grid.Row="1" x:Name="CmbSaveType" Style="{StaticResource TypeComboBox}" SelectedIndex="0" SelectionChanged="CmbSaveType_SelectionChanged" IsManipulationEnabled="True" IsReadOnly="True">
                <ComboBoxItem Content="指定路径"/>
                <ComboBoxItem Content="来源路径"/>
            </ComboBox>
        </Grid>

        <!-- 第四行：进度条 -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="转换进度" Style="{StaticResource LabelStyle}" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtProgress" Text="0%" Foreground="#CDD6F4" FontSize="12" FontFamily="{StaticResource MonoSpaceFamily}" HorizontalAlignment="Right"/>
            </Grid>
            <ProgressBar Grid.Row="1" x:Name="ProgressBar" Style="{StaticResource ModernProgressBar}" Minimum="0" Maximum="100" Value="0"/>
        </Grid>

        <!-- 第五行：转换按钮 -->
        <Button Grid.Row="4" x:Name="BtnConvert" Content="转换" Style="{StaticResource AccentButton}" MaxWidth="128" ToolTip="转换文件"  Click="BtnConvert_Click"/>
        <Button Grid.Row="4" x:Name="BtnUpdateMeta" Content="" HorizontalAlignment="Right" Style="{StaticResource AccentButton}" MaxWidth="48" ToolTip="更新元数据及文件名" Click="BtnUpdateMeta_Click"/>
        <Button Grid.Row="4" x:Name="BtnPlayM4A" Content="" HorizontalAlignment="Left" Style="{StaticResource AccentButton}" MaxWidth="48" ToolTip="播放文件" Click="BtnPlayM4A_Click"/>

        <!-- 第六行：状态提示 -->
        <TextBlock Grid.Row="5" x:Name="TxtStatus" Text="就绪" Foreground="#585B70" FontSize="11" Margin="0,4,0,0"/>
    </Grid>
</Window>
